---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">Música</h1>
    
    <div class="mb-12">
      <h2 class="text-2xl font-semibold mb-4">Escuchar en plataformas</h2>
      <div class="flex gap-4 flex-wrap">
        <a href="#" class="bg-black text-white px-4 py-2 rounded">Spotify</a>
        <a href="#" class="bg-orange-600 text-white px-4 py-2 rounded">SoundCloud</a>
        <a href="#" class="bg-red-600 text-white px-4 py-2 rounded">YouTube</a>
        <a href="#" class="bg-green-700 text-white px-4 py-2 rounded">Beatport</a>
        <a href="#" class="bg-gray-800 text-white px-4 py-2 rounded">Apple Music</a>
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-semibold mb-4">Releases destacados</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="border p-4 rounded">
          <h3 class="font-bold">Track 1</h3>
          <p>2024</p>
        </div>
        <div class="border p-4 rounded">
          <h3 class="font-bold">Track 2</h3>
          <p>2023</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>