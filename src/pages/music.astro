---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="max-w-4xl mx-auto px-4 py-24">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 text-center">
      Música<span class="text-purple-500">.</span>
    </h1>
    <p class="text-gray-400 text-center mb-12 text-lg">
      Escuchá mis sets en SoundCloud
    </p>

    <div class="space-y-8">
      <!-- Set Nebular -->
      <div class="bg-black/50 border border-purple-500/20 rounded-lg p-4">
        <iframe 
          width="100%" 
          height="166" 
          scrolling="no" 
          frameborder="no" 
          allow="autoplay" 
          src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/2251167881&color=%239314db&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"
          class="rounded"
        >
        </iframe>
        <div class="mt-2 text-xs text-gray-500">
          <a href="https://soundcloud.com/florencia-luna-944277749" title="Florencia Luna" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            Florencia Luna
          </a> · 
          <a href="https://soundcloud.com/florencia-luna-944277749/flor-moon-set-nebular-03012026" title="Flor Moon (Set Nebular) 03/01/2026" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            Flor Moon (Set Nebular) 03/01/2026
          </a>
        </div>
      </div>

      <!-- Melodic Techno Set -->
      <div class="bg-black/50 border border-purple-500/20 rounded-lg p-4">
        <iframe 
          width="100%" 
          height="166" 
          scrolling="no" 
          frameborder="no" 
          allow="autoplay" 
          src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/2200452079&color=%239314db&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"
          class="rounded"
        >
        </iframe>
        <div class="mt-2 text-xs text-gray-500">
          <a href="https://soundcloud.com/florencia-luna-944277749" title="Florencia Luna" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            Florencia Luna
          </a> · 
          <a href="https://soundcloud.com/florencia-luna-944277749/melodic-techno-set" title="MELODIC TECHNO SET" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            MELODIC TECHNO SET
          </a>
        </div>
      </div>

      <!-- Open -->
      <div class="bg-black/50 border border-purple-500/20 rounded-lg p-4">
        <iframe 
          width="100%" 
          height="166" 
          scrolling="no" 
          frameborder="no" 
          allow="autoplay" 
          src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/2107100745&color=%239314db&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"
          class="rounded"
        >
        </iframe>
        <div class="mt-2 text-xs text-gray-500">
          <a href="https://soundcloud.com/florencia-luna-944277749" title="Florencia Luna" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            Florencia Luna
          </a> · 
          <a href="https://soundcloud.com/florencia-luna-944277749/open" title="Open" target="_blank" class="text-gray-400 hover:text-purple-400 transition">
            Open
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>