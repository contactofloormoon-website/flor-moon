---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="max-w-6xl mx-auto px-4 pt-24 pb-16">
    <h1 class="text-4xl font-bold mb-8 text-white">Próximas<span class="text-purple-500"> Fechas</span></h1>
    <div class="aspect-video w-full">
      <iframe
        src="https://lu.ma/embed/calendar/cal-JKHe1IXunhudh1J/events"
        class="w-full h-full rounded-lg border border-purple-500/20"
        style="border: none;"
        allowfullscreen
        aria-hidden="false"
        tabindex="0"
      ></iframe>
    </div>
  </section>
</BaseLayout>