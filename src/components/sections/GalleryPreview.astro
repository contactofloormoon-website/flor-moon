---
// Imágenes 1 a 3 para preview
const galleryImages = [
  { src: '/images/gallery/1.jpg', alt: 'Flor Moon presentándose 1' },
  { src: '/images/gallery/2.jpg', alt: 'Flor Moon presentándose 2' },
  { src: '/images/gallery/3.jpg', alt: 'Flor Moon presentándose 3' }
];
---

<section class="bg-black py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 text-center">
      Galería<span class="text-purple-500"> Visual</span>
    </h2>
    <p class="text-gray-400 text-center mb-12">Momentos y sets</p>

    <!-- Desktop: grid 3 columnas -->
    <div class="hidden md:grid md:grid-cols-3 gap-6 mb-12 justify-items-center">
      {galleryImages.map((img, idx) => (
        <div class="w-full max-w-[280px] aspect-[9/16] overflow-hidden rounded-lg cursor-pointer group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <!-- Móvil: carrusel Swiper -->
    <div class="block md:hidden relative w-full">
      <div class="swiper-container-mobile overflow-x-auto flex gap-4 snap-x snap-mandatory">
        {galleryImages.map((img, idx) => (
          <div class="w-4/5 flex-shrink-0 snap-center aspect-[9/16] overflow-hidden rounded-lg cursor-pointer group">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Link a galería completa -->
    <div class="text-center mt-12">
      <a href="/gallery" class="text-purple-400 border-b border-purple-500 pb-1 hover:text-purple-300 transition">
        Ver galería completa →
      </a>
    </div>
  </div>
</section>

<style>
  .swiper-container-mobile {
    scrollbar-width: thin;
    scrollbar-color: #a855f7 #1a1a1a;
  }
  .swiper-container-mobile::-webkit-scrollbar {
    height: 6px;
  }
  .swiper-container-mobile::-webkit-scrollbar-track {
    background: #1a1a1a;
    border-radius: 10px;
  }
  .swiper-container-mobile::-webkit-scrollbar-thumb {
    background: #a855f7;
    border-radius: 10px;
  }
</style>